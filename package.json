{
  "name": "remysql",
  "productName": "RemySQL",
  "version": "0.2.12",
  "description": "Een kleine Electron database-manager voor MariaDB en SQLite met tabs, filters en relatiesidebar.",
  "main": "src/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/remyhersbach/RemySQL.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "postinstall": "node scripts/patch-electron-dev.js",
    "release": "node scripts/release.js",
    "release:publish": "node scripts/release.js --publish",
    "create:sample": "node scripts/create-sample-db.js",
    "icon": "electron scripts/render-icon.js",
    "icon:dock": "electron scripts/render-icon-dock.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.remyhersbach.remysql",
    "copyright": "© 2025 Remy Hersbach",
    "directories": {
      "output": "dist"
    },
    "files": [
      "CHANGELOG.md",
      "src/**/*",
      "assets/icon.png",
      "assets/icon-dock.png",
      "assets/logo.png"
    ],
    "mac": {
      "icon": "assets/icon-dock.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "remyhersbach",
        "repo": "RemySQL"
      }
    ]
  },
  "keywords": [
    "electron",
    "mariadb",
    "mysql",
    "sqlite",
    "database",
    "manager"
  ],
  "author": "Remy Hersbach",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "mariadb": "^3.5.2",
    "node-pty": "^1.1.0"
  }
}
